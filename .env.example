# Copy to .env and fill in. Never commit .env.

# Supabase (project Settings -> API). Run supabase/schema.sql in the SQL editor first.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8

# Embeddings — Voyage AI (https://dash.voyageai.com — 200M free tokens, then $0.02/1M)
VOYAGE_API_KEY=
# EMBEDDINGS_PROVIDER=voyage
# EMBEDDINGS_MODEL=voyage-3.5-lite
# EMBEDDINGS_DIM=1024        # must match vector(N) in supabase/schema.sql

# Retrieval tuning (defaults shown)
# TOP_K=5
# MIN_SIMILARITY=0.30        # best-match similarity below this -> honest "I don't know"
