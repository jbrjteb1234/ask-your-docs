# Copy to .env and fill in. Never commit .env.

# Supabase (project Settings -> API). Run supabase/schema.sql in the SQL editor first.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-5   # app default; claude-opus-4-8 for max quality, claude-haiku-4-5 for min cost

# Embeddings — Voyage AI (https://dash.voyageai.com — 200M free tokens, then $0.02/1M)
VOYAGE_API_KEY=
# EMBEDDINGS_PROVIDER=voyage
# EMBEDDINGS_MODEL=voyage-3.5-lite
# EMBEDDINGS_DIM=1024        # must match vector(N) in supabase/schema.sql

# Retrieval tuning (defaults shown)
# TOP_K=5
# MIN_SIMILARITY=0.30        # best-match similarity below this -> honest "I don't know"

# M2 — admin view + widget
ADMIN_KEY=                   # shared key for /admin, /ingest, /documents (generate a long random one)
CONTACT_EMAIL=               # shown as the human handoff when the assistant can't answer
# RATE_LIMIT_PER_MIN=10      # public /ask requests allowed per IP per minute

# Deployment
# TRUST_PROXY=true           # set true ONLY behind a proxy you control (Railway/nginx) so the
                             # rate limiter reads the real client IP; leave off if directly exposed.
# PORT is injected by the platform (Railway); no need to set it locally (defaults to 8000).
